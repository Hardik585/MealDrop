
# ========================================
# Root-level .gitignore
# Covers both frontend and backend
# ========================================

### OS ###
.DS_Store
Thumbs.db
Desktop.ini

### Logs ###
*.log

### Archives ###
*.zip
*.tar.gz
*.rar

### Temp files ###
*.tmp
*.bak
*.swp
*.swo
*.orig
*.rej

# ========================================
# FRONTEND (React, Angular, Vue, etc.)
# ========================================
frontend/node_modules/
frontend/dist/
frontend/package-lock.json
frontend/yarn.lock
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production

# ========================================
# admin panel (React, Angular, Vue, etc.)
# ========================================
adminpanel/node_modules/
adminpanel/dist/
adminpanel/package-lock.json
adminpanel/yarn.lock
adminpanel/.env
adminpanel/.env.local
adminpanel/.env.development
adminpanel/.env.production
adminpanel/src/components/test/

# ========================================
# BACKEND (Spring Boot project inside backend/my-sts-project)
# ========================================

# Build and output directories
backend/target/
backend/build/
backend/bin/
backend/out/
backend/.gitignore

# Maven/Gradle
backend/.mvn/
backend/.gradle/
backend/mvnw
backend/mvnw.cmd
backend/gradlew
backend/gradlew.bat


# Environment/config
backend/.env
backend/application-*.yml
backend/application-*.properties

# Optional: hide production config files
backend/src/main/resources/application-prod.yml
backend/src/main/resources/application-prod.properties

# ========================================
# IDE-specific
# ========================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr


# VS Code
.vscode/

/.metadata/

